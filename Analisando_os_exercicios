def potencia_de_dois(n):
   i = 1 
   while i < n:
      print(i)
      i *= 2

#complexidade: O(log n) - A função imprime potências de 2 até que i seja menor que n, onde n é o número de entrada. A cada iteração, i é multiplicado por 2, o que resulta em um crescimento logarítmico em relação a n.

