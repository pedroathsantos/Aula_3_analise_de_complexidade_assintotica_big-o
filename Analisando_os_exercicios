def pares_com_soma(lista, alvo):
   for i in range(len(lista)):
      for j in range(i + 1, len(lista)):
         if lista[i] + lista[j] == alvo:
            print(lista[i], lista[j])

#complexidade: O(n^2) - A função utiliza dois loops aninhados para verificar todas as combinações possíveis de pares na lista, onde n é o número de elementos na lista.

