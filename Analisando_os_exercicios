def ordenacao_bolha(lista):
   n = len(lista)
   for i in range(n):
      for j in range(0, n - i - 1):
         if lista[j] > lista[j + 1]:
            lista[j], lista[j + 1] = lista[j + 1], lista[j]
   return lista

#complexidade: O(n^2) - O algoritmo de ordenação bolha tem uma complexidade quadrática devido aos dois loops aninhados que percorrem a lista para comparar e trocar elementos, onde n é o número de elementos na lista.

def produto_matrizes(A, B, n):
   C = [[0] * n for _ in range(n)]
   for i in range(n):
      for j in range(n):
         for k in range(n):
            C[i][j] += A[i][k] * B[k][j]
   return C

#complexidade: O(n^3) - O algoritmo de multiplicação de matrizes tem uma complexidade cúbica devido aos três loops aninhados que percorrem as matrizes para calcular o produto, onde n é o tamanho das matrizes.

