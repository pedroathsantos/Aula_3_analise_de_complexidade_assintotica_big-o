def busca_bineria(lista, alvo):
   esquerda, direita = 0, len(lista) - 1
   while esquerda <= direita:
      meio = (esquerda + direita) // 2
      if lista[meio] == alvo:
         return meio
      elif lista[meio] < alvo:
         esquerda = meio + 1
      else:
         direita = meio - 1
   return -1

#complexidade: O(log n) - A busca binária reduz o espaço de busca pela metade a cada iteração, onde n é o número de elementos na lista.

